# Production Environment Variables for Hostinger MySQL

# MySQL Database Connection (get these from Hostinger cPanel)
DB_HOST=your-hostinger-mysql-host
DB_USER=your-database-user
DB_PASSWORD=your-database-password
DB_NAME=your-database-name

# Node.js Environment
NODE_ENV=production

# JWT Secret (for authentication)
JWT_SECRET=your-secure-jwt-secret-key-here

# API Configuration
CORS_ORIGINS=https://yourdomain.com

# Optional: Server Port (Hostinger may assign this automatically)
PORT=3000

# Instructions:
# 1. Get DB_HOST, DB_USER, DB_PASSWORD from Hostinger cPanel > MySQL Databases
# 2. Create a new database in cPanel and set DB_NAME
# 3. Generate a random JWT_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 4. Replace CORS_ORIGINS with your actual domain
# 5. Upload this file as .env.production to your Hostinger server (keep it secure!)
